{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/core/**",
              "components/sportsbook/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Source Serif 4|Inter|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Source Serif 4, Inter, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|dot|uppercase|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, dot, uppercase."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|slate|ochre|burgundy|sage|ink|ficticia)$/]",
        "message": "<Badge> variant must be one of 'default' | 'slate' | 'ochre' | 'burgundy' | 'sage' | 'ink' | 'ficticia'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|onClick|type|fullWidth|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, onClick, type, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger|success|outline|dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger' | 'success' | 'outline' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|header|footer|flush|tinted|gradient|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, style, header, footer, flush, tinted, gradient."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|label|type|size|error|prefix|suffix|disabled|id|mono|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, label, type, size, error, prefix, suffix, disabled, id, mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|password|number|tel)$/]",
        "message": "<Input> type must be one of 'text' | 'email' | 'password' | 'number' | 'tel'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Input> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LedgerRule'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|margin|key|ref|className|style|children)$/]",
        "message": "<LedgerRule> doesn't accept that prop. Declared props: style, margin."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddsButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|odds|active|onClick|onDark|disabled|key|ref|className|style|children)$/]",
        "message": "<OddsButton> doesn't accept that prop. Declared props: label, odds, active, onClick, onDark, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='SbBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|dot|live|key|ref|className|style|children)$/]",
        "message": "<SbBadge> doesn't accept that prop. Declared props: children, variant, dot, live."
      },
      {
        "selector": "JSXOpeningElement[name.name='SbBadge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|accent|live|truth|cash|ficticia)$/]",
        "message": "<SbBadge> variant must be one of 'default' | 'accent' | 'live' | 'truth' | 'cash' | 'ficticia'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SbButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|onClick|glow|key|ref|className|style|children)$/]",
        "message": "<SbButton> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, onClick, glow."
      },
      {
        "selector": "JSXOpeningElement[name.name='SbButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|success|outline)$/]",
        "message": "<SbButton> variant must be one of 'primary' | 'secondary' | 'ghost' | 'success' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SbButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<SbButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SbOddsTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|odds|active|move|onClick|disabled|key|ref|className|style|children)$/]",
        "message": "<SbOddsTile> doesn't accept that prop. Declared props: label, odds, active, move, onClick, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='SbOddsTile'] > JSXAttribute[name.name='move'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<SbOddsTile> move must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tab'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|href|key|ref|className|style|children)$/]",
        "message": "<Tab> doesn't accept that prop. Declared props: children, active, onClick, href."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
