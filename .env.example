# Copia este archivo a .env.local y completa los valores reales.
# Las variables VITE_* se incrustan en el build del cliente (Vite),
# así que NO pongas aquí secretos de servidor (como la clave de
# API-Football: esa vive como secreto de la Cloud Function).

# --- Firebase (cliente) ---
# Vienen de la consola de Firebase: Project settings > General > Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Cuotas de fútbol ---
# URL pública de la Cloud Function `getOdds` (proxy a API-Football).
# La imprime `firebase deploy --only functions`. Ejemplo:
# https://us-central1-TU-PROYECTO.cloudfunctions.net/getOdds
# Si la dejas vacía, el cliente usa los datos de ejemplo (modo demo).
VITE_GETODDS_URL=
