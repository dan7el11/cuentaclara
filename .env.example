# Copia este archivo a .env.local y completa los valores reales.
# Las variables VITE_* se incrustan en el build del cliente (Vite),
# así que NO pongas aquí secretos de servidor.

# --- Firebase (cliente) ---
# Vienen de la consola de Firebase: Project settings > General > Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Notificaciones push (cliente) ---
# Par de claves Web Push: Firebase > Project settings > Cloud Messaging >
# "Web configuration" > Generate key pair. Pegá aquí la clave pública.
VITE_FIREBASE_VAPID_KEY=

# --- Cuotas de fútbol (cliente) ---
# URL pública de la función getOdds en Netlify. Ejemplo:
# https://TU-SITIO.netlify.app/.netlify/functions/getOdds
# Si la dejas vacía, el cliente usa los datos de ejemplo (modo demo).
VITE_GETODDS_URL=

# --- Variables de SERVIDOR (NO van en .env.local del cliente) ---
# Se configuran en Netlify > Site settings > Environment variables:
#   ODDS_API_KEY             -> clave de The Odds API (the-odds-api.com)
#   FIREBASE_SERVICE_ACCOUNT -> JSON completo de la cuenta de servicio de
#       Firebase (Project settings > Service accounts > Generate new private
#       key). Lo usa la función programada resolveBets para resolver apuestas
#       y enviar las push.
